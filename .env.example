# Docker Hub username (for image pulls)
DOCKERHUB_USERNAME=your-dockerhub-username

# Host port (adjust if 8081 is already in use)
APP_PORT=8081

# Local directory holding google-client-secret.json and google-tokens/
SECRETS_DIR=~/.mite-sync

# Mite source — main instance that is booked into daily (billing-relevant)
MITE_SYNC_SOURCE_HOST=your-org.mite.de
MITE_SYNC_SOURCE_API_KEY=
MITE_SYNC_SOURCE_PROJECT_ID=
MITE_SYNC_SOURCE_SERVICE_ID=
MITE_SYNC_SOURCE_MEETING_COLLECTOR_PBI=

# Mite target — mirror instance that /sync-jobs replicates into
MITE_SYNC_TARGET_HOST=your-mirror.mite.de
MITE_SYNC_TARGET_API_KEY=
MITE_SYNC_TARGET_PROJECT_ID=
MITE_SYNC_TARGET_SERVICE_ID=

# Google Calendar
DAILY_REPORTS_GOOGLE_CALENDAR_CALENDAR_ID=primary
DAILY_REPORTS_GOOGLE_CALENDAR_SKIP_SUMMARIES=

# Azure DevOps
DAILY_REPORTS_AZURE_DEVOPS_ORGANIZATION=your-org
DAILY_REPORTS_AZURE_DEVOPS_PROJECT=Your Project
DAILY_REPORTS_AZURE_DEVOPS_PAT=

# Booking rules (the defaults are fine for most cases)
DAILY_REPORTS_RULES_DAILY_EVENT_SUMMARY=Team Daily
DAILY_REPORTS_RULES_DAILY_FIXED_MINUTES=15
DAILY_REPORTS_RULES_ROUNDING_STEP_MINUTES=15
